# openclew - Development Environment
# Copy this file to .env before running locally
#   cp .env.example .env

# === Project ===
PROJECT_NAME=openclew
DEBUG=True
ENVIRONMENT=local

# === PostgreSQL ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=openclew

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# === JWT Secret (generate with: openssl rand -hex 32) ===
SECRET_KEY=change-me-in-development-use-openssl-rand-hex-32

# === OAuth2 (Google) ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/oauth/google/callback

# === Auth (API Key) ===
API_KEY=dev-api-key-change-in-production

# === Celery ===
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# === Prometheus ===
PROMETHEUS_METRICS_PATH=/metrics
PROMETHEUS_INCLUDE_IN_SCHEMA=False

# === S3/MinIO (optional) ===
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=openclew
S3_REGION=us-east-1

# === AI / OpenAI ===
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2000
AI_SUMMARIZATION_ENABLED=True
AI_QA_ENABLED=True
AI_QUIZ_GENERATION_ENABLED=True

# === AWS S3 (optional) ===
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=
AWS_S3_ENABLED=False
LOCAL_UPLOAD_DIR=/tmp/openstudy_uploads

# === CORS ===
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]
CORS_ALLOW_CREDENTIALS=True
